{
  "name": "agentledger",
  "version": "0.1.0",
  "description": "Local-first session review for Claude Code and OpenAI Codex",
  "private": true,
  "type": "module",
  "license": "MIT",
  "bin": {
    "agentledger": "./apps/cli/dist/index.js"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -p tsconfig.check.json --noEmit --pretty false",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "cli": "tsx apps/cli/src/index.ts"
  },
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.15.1",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.15"
  }
}
