{
  "name": "codeoutcome",
  "version": "0.1.0-alpha.1",
  "description": "Local-first outcome tracking for Claude Code and Codex sessions",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vsn75rgcpx-sudo/codeoutcome.git"
  },
  "homepage": "https://github.com/vsn75rgcpx-sudo/codeoutcome#readme",
  "bugs": {
    "url": "https://github.com/vsn75rgcpx-sudo/codeoutcome/issues"
  },
  "bin": {
    "codeoutcome": "./apps/cli/dist/index.js"
  },
  "scripts": {
    "build": "tsc -b && pnpm dashboard:build",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -p tsconfig.check.json --noEmit --pretty false",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "dashboard:dev": "pnpm dashboard:build && pnpm cli dashboard --no-open",
    "dashboard:build": "pnpm --filter @codeoutcome/dashboard build",
    "dashboard:test": "vitest run packages/dashboard-server apps/dashboard apps/cli/src/dashboard-cli.test.ts",
    "demo:seed": "tsx scripts/demo-seed.ts",
    "demo:dashboard": "pnpm demo:seed && pnpm dashboard:build && CODEOUTCOME_DATA_DIR=$PWD/artifacts/demo pnpm cli dashboard --no-open",
    "demo:smoke": "pnpm demo:seed && pnpm dashboard:build && tsx scripts/demo-dashboard-smoke.ts",
    "demo:screenshots": "pnpm dashboard:build && tsx scripts/demo-screenshots.ts",
    "e2e": "pnpm dashboard:build && playwright test",
    "accessibility:test": "pnpm dashboard:build && playwright test apps/dashboard-e2e/accessibility.spec.ts",
    "package:build": "pnpm build && tsx scripts/package-prepare.ts && vite build --config packaging/vite.config.ts",
    "package:pack": "pnpm package:build && tsx scripts/package-pack.ts",
    "package:inspect": "tsx scripts/package-inspect.ts",
    "package:test-install": "tsx scripts/package-test-install.ts",
    "cli": "tsx apps/cli/src/index.ts"
  },
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.15.1",
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "1.61.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "8.1.5",
    "vitest": "^4.0.15"
  }
}
